# Ek-Chuah MCP (MCP-AEC) -- Environment Variables
#
# Local: cp .env.example .env
# Railway: configurar como variables del servicio (apuntando a ESTE repo,
#          no al substrato Ek-Chuah)

# ═══════════════════════════════════════════════════════════
# REQUERIDAS
# ═══════════════════════════════════════════════════════════

# PostgreSQL del graph_aec (store NUEVO dedicado al AEC; NO el de concept-sediment).
# El rol DEBE ser usuario solo-lectura para el servicio del lector (defensa exterior
# de la membrana). El rebuild (projection_build.py) usa un rol con escritura aparte.
DATABASE_URL=postgresql://user:password@host:port/ek_chuah_aec

# OpenAI API Key (embeddings de aec_search). Sin ella, aec_search cae a ILIKE.
OPENAI_API_KEY=sk-proj-your-key-here

# ═══════════════════════════════════════════════════════════
# OPCIONALES
# ═══════════════════════════════════════════════════════════

# MCP_PORT=8000              # Railway inyecta PORT automaticamente
# MCP_HOST=0.0.0.0
# EMBEDDING_MODEL=text-embedding-3-small

# Reconstruir graph_aec de aec_log al arrancar (camino B). Default: off.
# Util en boot tras replicar el log. Requiere rol con escritura.
# AEC_REBUILD_ON_BOOT=1
